{
  "expo": {
    "name": "PreciMap",
    "slug": "precimap",
    "scheme": "com.kamsito.precimap",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "description": "Compara precios de gasolina, supermercados y bancos en toda España. Ahorra dinero con la comunidad.",
    "primaryColor": "#2563EB",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kamsito.precimap",
      "buildNumber": "25",
      "requireFullScreen": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "PreciMap usa tu ubicación para mostrarte las gasolineras más baratas y lugares cercanos.",
        "NSCameraUsageDescription": "PreciMap necesita la cámara para fotografiar precios y chollos.",
        "NSPhotoLibraryUsageDescription": "PreciMap necesita tu galería para subir fotos de chollos y tu avatar.",
        "NSPhotoLibraryAddUsageDescription": "PreciMap guarda fotos de precios en tu galería.",
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "com.amazon.mobile.shopping.web",
          "amazon-spain",
          "amazon"
        ]
      },
      "deploymentTarget": "15.1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      },
      "package": "com.kamsito.precimap",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-location",
      [
        "expo-image-picker",
        {
          "photosPermission": "PreciMap necesita acceso a tu galería para subir fotos de chollos.",
          "cameraPermission": "PreciMap necesita acceso a la cámara para fotografiar precios."
        }
      ],
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "eebf715f-1226-4c39-a0c3-53dbb363bd13"
      }
    },
    "owner": "kamsito1",
    "privacy": "public",
    "keywords": [
      "gasolina",
      "supermercado",
      "precios",
      "ahorro",
      "España",
      "chollos",
      "farmacia",
      "ofertas"
    ]
  },
  "react-native-google-mobile-ads": {
    "ios_app_id": "ca-app-pub-4854549477350471~3682160177"
  }
}